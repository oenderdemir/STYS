# Database
STYS_DB_HOST=mssql
STYS_DB_PORT=1433
STYS_DB_HOST_PORT=14333
STYS_DB_NAME=STYSDB
STYS_DB_USER=sa
STYS_DB_PASSWORD=Strong!Pass1
STYS_DB_ENCRYPT=False
STYS_DB_TRUST_SERVER_CERTIFICATE=True
STYS_DB_MARS=True

# JWT
STYS_JWT_KEY=123456aAa.!!
STYS_JWT_ISSUER=TOD.Platform
STYS_JWT_AUDIENCE=TOD.Platform.Clients
STYS_JWT_ACCESS_MINUTES=30
STYS_JWT_REFRESH_DAYS=7
STYS_JWT_RETENTION_DAYS=30
STYS_JWT_CLEANUP_INTERVAL_HOURS=24
STYS_JWT_CLEANUP_STARTUP_DELAY_MINUTES=2

# API
STYS_ENABLE_SWAGGER=true
STYS_SWAGGER_AUTH_USERNAME=swagger
STYS_SWAGGER_AUTH_PASSWORD=Swagger_2026

# Rate limiting
STYS_RATE_LIMIT_ENABLED=true
STYS_RATE_LIMIT_PERMIT_LIMIT=120
STYS_RATE_LIMIT_WINDOW_SECONDS=60
STYS_RATE_LIMIT_QUEUE_LIMIT=0
STYS_RATE_LIMIT_QUEUE_ORDER=OldestFirst
STYS_RATE_LIMIT_REJECTION_STATUS_CODE=429
STYS_RATE_LIMIT_REJECTION_MESSAGE=Too many requests.
STYS_RATE_LIMIT_REJECTION_ERROR_CODE=RATE_LIMITED
STYS_RATE_LIMIT_REJECTION_DETAIL=Too many requests. Please try again later.
STYS_RATE_LIMIT_UNKNOWN_CLIENT_IP=unknown

# Logging
STYS_LOG_ARCHIVE_DIRECTORY_FORMAT=/app/Logs/archive/{UtcDate:yyyy}/{UtcDate:MM}
STYS_LOG_LEVEL_DEFAULT=Information
STYS_LOG_LEVEL_MICROSOFT=Warning
STYS_LOG_LEVEL_ASPNETCORE=Warning
STYS_LOG_LEVEL_SYSTEM=Warning
STYS_LOG_FILE_PATH=/app/Logs/stys-.log
STYS_LOG_FILE_SIZE_LIMIT_BYTES=10485760
STYS_LOG_RETAINED_FILE_COUNT_LIMIT=14
